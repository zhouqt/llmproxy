# Example secrets file for llmproxy.
#
# Copy this file to `.env` (gitignored) and fill in real values before
# `docker compose up`. Required when `LLMPROXY_API_KEY` is left empty:
# the proxy rejects requests whose `x-api-key` header does not match.
#
# Empty values disable the corresponding provider (the chain skips
# providers with missing/empty credentials).

# Required: any non-empty string shared with your clients.
LLMPROXY_API_KEY=

# Provider credentials. Leave empty to disable a provider.
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
OPENCODE_API_KEY=

# Optional: tracing filter. Defaults to "info" if unset. The proxy
# only reads this when docker-compose.yaml exports it via
# `environment: - RUST_LOG`; remove that line if you do not want it.
# RUST_LOG=info,llmproxy=debug
